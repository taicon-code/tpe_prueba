# ============================================================
#  .env.example — Copiar como .env y completar con tus datos
#  NUNCA subir el .env real a Git, solo este .env.example
# ============================================================

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos MySQL
DB_NAME=db_sumarios_militares
DB_USER=root
DB_PASSWORD=tu-password-aqui
DB_HOST=127.0.0.1
DB_PORT=3306

# Archivos media (fotos PM, PDFs adjuntos) — apunta a OneDrive o disco externo
# NUNCA dentro del proyecto. Django crea subcarpetas automaticamente.
MEDIA_ROOT=C:/Users/USUARIO/OneDrive/1. TPE/2. TPE GRAL/media_tpe/
MEDIA_URL=/media/
