# ============================================================
#  .env.example — Copiar como .env y completar con tus datos
#  NUNCA subir el .env real a Git, solo este .env.example
# ============================================================

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos MySQL
DB_NAME=db_sumarios_militares
DB_USER=root
DB_PASSWORD=tu-password-aqui
DB_HOST=127.0.0.1
DB_PORT=3306

# Archivos media (PDFs escaneados)
# PC trabajo ejemplo:    C:/proyectos/tpe/media/
# Laptop ejemplo:        C:/Users/TuNombre/proyectos/tpe/media/
# OneDrive recomendado:  C:/Users/TuNombre/OneDrive/tpe_media/
MEDIA_ROOT=C:/Users/TuNombre/OneDrive/tpe_media/
MEDIA_URL=/media/
