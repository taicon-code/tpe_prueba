# ============================================================
#  .gitignore — Proyecto TPE/TSP (Django + MySQL)
# ============================================================

# --- Entorno virtual Python ---
venv/
env/
.venv/
ENV/

# --- Variables de entorno (NUNCA subir al repo) ---
.env
.env.local
.env.production
*.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# --- Django ---
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# --- Archivos de media (PDFs escaneados, imágenes subidas) ---
media/
mediafiles/

# --- Archivos estáticos recolectados (generados por collectstatic) ---
staticfiles/
static_root/

# --- Migraciones (opcional: algunos equipos sí las suben) ---
# Si trabajas solo en este proyecto, comenta estas líneas
# */migrations/0*.py

# --- Backups de base de datos ---
*.sql
backups/
backup_*/

# --- Editores e IDEs ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# --- Sistema operativo ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Node.js (si usas npm para frontend) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Certificados y claves ---
*.pem
*.key
*.cert
*.crt

# --- Pytest / coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Jupyter (si usas notebooks) ---
.ipynb_checkpoints/
*.ipynb

# Entorno virtual
venv/
env/
C:/venv_tpe/

# Variables de entorno
.env

# Base de datos y backups
BBDD/
*.sql
db.sqlite3

# Python
__pycache__/
*.pyc

# Sistema
.DS_Store
Thumbs.db

# docs/
docs/

# Claude Code (worktrees, configuración local)
.claude/